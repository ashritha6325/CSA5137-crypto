#include <stdio.h>
#include <string.h>
#include <ctype.h>

int main() {
    char plaintext[100], key[100], ciphertext[100];
    int i, j;

    printf("Enter Plaintext: ");
    scanf("%s", plaintext);

    printf("Enter Key: ");
    scanf("%s", key);

    int p_len = strlen(plaintext);
    int k_len = strlen(key);

    for(i = 0, j = 0; i < p_len; i++, j++) {
        if(j == k_len)
            j = 0;

        int shift = tolower(key[j]) - 'a';
        ciphertext[i] = ((tolower(plaintext[i]) - 'a' + shift) % 26) + 'a';
    }

    ciphertext[i] = '\0';

    printf("Ciphertext: %s", ciphertext);

    return 0;
}
